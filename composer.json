{
    "name": "tcgunel/omnipay-qnbfinansbank",
    "type": "library",
    "description": "Omnipay extension for QNB Finansbank",
    "keywords": [
        "qnbfinansbank",
        "qnb finansbank",
        "finansbank",
        "omnipay",
        "payment",
        "gateway",
        "3d secure",
        "sanal pos"
    ],
    "homepage": "https://github.com/tcgunel/omnipay-qnbfinansbank",
    "license": "MIT",
    "authors": [
        {
            "name": "Tolga Can Gunel",
            "email": "tlgcngnl@gmail.com"
        },
        {
            "name": "Omnipay Contributors",
            "homepage": "https://github.com/tcgunel/omnipay-qnbfinansbank/contributors"
        }
    ],
    "autoload": {
        "psr-4": {
            "Omnipay\\QnbFinansbank\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Omnipay\\QnbFinansbank\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.3",
        "league/omnipay": "^3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9",
        "omnipay/tests": "^4",
        "brianium/paratest": "*",
        "fzaninotto/faker": "*",
        "http-interop/http-factory-guzzle": "^1.2",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.0"
    },
    "scripts": {
        "test": "vendor/bin/paratest --processes 6",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": "vendor/bin/pint",
        "lint-check": "vendor/bin/pint --test"
    }
}
